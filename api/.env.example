# Echo API — copy to .env and fill in
PORT=3048
CORS_ORIGIN=http://localhost:3047
# Production (DigitalOcean managed Postgres). The WAL/busy_timeout pragmas in
# prisma.service only fire for file: URLs, so they NO-OP here.
DATABASE_URL="postgresql://USER:PASS@HOST:5432/echo?sslmode=require"
# Local dev (disposable SQLite) — uncomment to develop without a Postgres:
# DATABASE_URL="file:./dev.db"

# Object storage. local = write to ./data (dev only; App Platform FS is ephemeral).
# r2 = Cloudflare R2 (S3-compatible, PRIVATE bucket) for durable prod media.
STORAGE_DRIVER=local
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=echo-media
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto

# OpenRouter (LLM). Without a key the API runs in demo/stub mode.
OPENROUTER_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
EXTRACT_MODEL=deepseek/deepseek-chat
CHAT_MODEL=deepseek/deepseek-chat
VISION_MODEL=qwen/qwen3-vl-8b-instruct
MAX_MEMORY_CALLS=12
# Phase 3 Generative-Agents retrieval. Memories are embedded once at write-time
# (cosine relevance term). Default model via OpenRouter; set EMBED_PROVIDER=fal to
# use a fal embedding model instead. Absent key -> retrieval falls back to keywords.
EMBED_MODEL=openai/text-embedding-3-small
# EMBED_PROVIDER=openrouter   # or 'fal'

# fal.ai (selfie image edit). Without a key /selfie returns 501.
FAL_KEY=
FAL_EDIT_MODEL=fal-ai/qwen-image-edit
# Speech-to-text (voice in). Without a key the chat audio path returns 501.
FAL_STT_MODEL=fal-ai/whisper

# Proactive nudges (she texts first). Random window in minutes between messages.
NUDGE_MIN_MIN=20
NUDGE_MAX_MIN=90

# Text-to-speech (voice out / "her voice"). Without a key the voice path is skipped (text fallback).
FAL_TTS_MODEL=fal-ai/elevenlabs/tts/multilingual-v2
FAL_TTS_VOICE_FEMALE=Sarah
FAL_TTS_VOICE_MALE=Brian
FAL_VOICE_CLONE_MODEL=fal-ai/minimax/voice-clone
FAL_TTS_CLONE_MODEL=fal-ai/minimax/speech-02-hd

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
# Without these keys the push path is disabled (GET /push/key returns null).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@echo.app
