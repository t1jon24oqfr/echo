  "messages": [
    { "id": 1, "type": "message", "date": "2025-11-03T22:14:05", "from": "Майя", "text": "макс ти живий взагалі" },
    { "id": 2, "type": "message", "date": "2025-11-03T22:14:21", "from": "Майя", "text": "бо я тут вмираю над макетом 😭" },
    { "id": 3, "type": "message", "date": "2025-11-03T22:16:02", "from": "Макс", "text": "живий) що там у тебе" },
    { "id": 4, "type": "message", "date": "2025-11-03T22:16:40", "from": "Майя", "text": "клієнт хоче лого «як у эпл але щоб веселіше»" },
    { "id": 5, "type": "message", "date": "2025-11-03T22:16:55", "from": "Майя", "text": "ору. як у эпл. але веселіше. ОК" },
    { "id": 6, "type": "message", "date": "2025-11-03T22:17:30", "from": "Макс", "text": "намалюй йому яблуко в клоунському носі" },
    { "id": 7, "type": "message", "date": "2025-11-03T22:18:01", "from": "Майя", "text": "пхпхпх не спокушай" },
    { "id": 8, "type": "message", "date": "2025-11-03T22:18:14", "from": "Майя", "text": "крч я ще годину посиджу і спать. добраніч пельмень ✨" },
    { "id": 9, "type": "message", "date": "2025-11-12T13:02:10", "from": "Майя", "text": "СТОП" },
    { "id": 10, "type": "message", "date": "2025-11-12T13:02:18", "from": "Майя", "text": "я знов загубила навушники" },
    { "id": 11, "type": "message", "date": "2025-11-12T13:02:26", "from": "Майя", "text": "це вже треті за рік. я офіційно лох" },
    { "id": 12, "type": "message", "date": "2025-11-12T13:05:44", "from": "Макс", "text": "ахаха ну хто б сумнівався. дивилась в куртці з капюшоном?" },
    { "id": 13, "type": "message", "date": "2025-11-12T13:08:02", "from": "Майя", "text": "..." },
    { "id": 14, "type": "message", "date": "2025-11-12T13:08:09", "from": "Майя", "text": "вони були в капюшоні" },
    { "id": 15, "type": "message", "date": "2025-11-12T13:08:15", "from": "Майя", "text": "нічого не кажи 😼" },
    { "id": 16, "type": "message", "date": "2025-11-12T13:09:00", "from": "Макс", "text": "я нічого не казав)) але запам'ятаю" },
    { "id": 17, "type": "message", "date": "2025-11-28T01:33:12", "from": "Макс", "text": "не спиш?" },
    { "id": 18, "type": "message", "date": "2025-11-28T01:34:40", "from": "Майя", "text": "капібара-режим: лежу дивлюсь відосики і ні про що не думаю" },
    { "id": 19, "type": "message", "date": "2025-11-28T01:35:02", "from": "Майя", "text": "а ти чого не спиш малий" },
    { "id": 20, "type": "message", "date": "2025-11-28T01:36:11", "from": "Макс", "text": "та думаю всяке. про роботу, про нас" },
    { "id": 21, "type": "message", "date": "2025-11-28T01:37:05", "from": "Майя", "text": "про нас можна думати тільки хороше, я перевіряла" },
    { "id": 22, "type": "message", "date": "2025-11-28T01:37:30", "from": "Майя", "text": "іди спать. я тебе люблю, дурник ✨" },
    { "id": 23, "type": "message", "date": "2025-12-06T16:20:00", "from": "Майя", "text": "БОРЩ ВТІК З КЛІТКИ" },
    { "id": 24, "type": "message", "date": "2025-12-06T16:20:08", "from": "Майя", "text": "повторюю. хом'як на свободі" },
    { "id": 25, "type": "message", "date": "2025-12-06T16:20:15", "from": "Майя", "text": "це не навчальна тривога!!" },
    { "id": 26, "type": "message", "date": "2025-12-06T16:22:30", "from": "Макс", "text": "ахахаха шукай за шафою, він минулого разу там тусив" },
    { "id": 27, "type": "message", "date": "2025-12-06T16:40:12", "from": "Майя", "text": "знайшла. сидів у моєму кросівку" },
    { "id": 28, "type": "message", "date": "2025-12-06T16:40:25", "from": "Майя", "text": "жесть він мене довів сьогодні 😭 але такий милий шо неможливо злитись" },
    { "id": 29, "type": "message", "date": "2025-12-06T16:41:00", "from": "Макс", "text": "він в тебе вдався характером)" },
    { "id": 30, "type": "message", "date": "2025-12-06T16:41:33", "from": "Майя", "text": "це був комплімент чи наїзд? думай швидко" },
    { "id": 31, "type": "message", "date": "2025-12-06T16:42:01", "from": "Макс", "text": "комплімент звичайно" },
    { "id": 32, "type": "message", "date": "2025-12-06T16:42:20", "from": "Майя", "text": "correct answer 😼" },
    { "id": 33, "type": "message", "date": "2025-12-19T19:05:10", "from": "Макс", "text": "слухай а поїхали у львів на вихідні" },
    { "id": 34, "type": "message", "date": "2025-12-19T19:06:33", "from": "Майя", "text": "ТАК" },
    { "id": 35, "type": "message", "date": "2025-12-19T19:06:41", "from": "Майя", "text": "я вже пакуюсь подумки" },
    { "id": 36, "type": "message", "date": "2025-12-19T19:06:58", "from": "Майя", "text": "хочу ту каву з чорницею з рукавички і шоб дощ і бруківка" },
    { "id": 37, "type": "message", "date": "2025-12-19T19:08:00", "from": "Макс", "text": "домовились. білети беру на суботу ранок" },
    { "id": 38, "type": "message", "date": "2025-12-19T19:08:40", "from": "Майя", "text": "ти найкращий. офіційно заявляю ✨" },
    { "id": 39, "type": "message", "date": "2025-12-22T23:55:01", "from": "Майя", "text": "макс" },
    { "id": 40, "type": "message", "date": "2025-12-22T23:55:09", "from": "Майя", "text": "а пам'ятаєш як ми о 4 ранку варили пельмені і ти забув воду посолити" },
    { "id": 41, "type": "message", "date": "2025-12-22T23:55:30", "from": "Майя", "text": "я досі сміюсь коли згадую твоє лице" },
    { "id": 42, "type": "message", "date": "2025-12-22T23:57:12", "from": "Макс", "text": "вони все одно були їстівні!" },
    { "id": 43, "type": "message", "date": "2025-12-22T23:57:45", "from": "Майя", "text": "вони були СУМНІ. як і ти без мене пхпх" },
    { "id": 44, "type": "message", "date": "2025-12-22T23:58:30", "from": "Макс", "text": "ну тут не посперечаєшся" },
    { "id": 45, "type": "message", "date": "2025-12-31T23:48:00", "from": "Майя", "text": "так. поки всі кричать і ріжуть олів'є" },
    { "id": 46, "type": "message", "date": "2025-12-31T23:48:20", "from": "Майя", "text": "хочу сказати шо цей рік був найкращий через тебе" },
    { "id": 47, "type": "message", "date": "2025-12-31T23:48:35", "from": "Майя", "text": "і нє, я не плачу, це мандарини в око попали 🥲" },
    { "id": 48, "type": "message", "date": "2025-12-31T23:50:02", "from": "Макс", "text": "ти моє найкраще шо було за всі роки. з новим роком, мала" },
    { "id": 49, "type": "message", "date": "2025-12-31T23:50:40", "from": "Майя", "text": "з новим роком пельмень ✨🎄" },
    { "id": 50, "type": "message", "date": "2026-01-14T12:10:05", "from": "Майя", "text": "понеділок — скам. вівторок до речі теж" },
    { "id": 51, "type": "message", "date": "2026-01-14T12:10:30", "from": "Майя", "text": "клієнт повернув макет з правкою «зробіть красиво»" },
    { "id": 52, "type": "message", "date": "2026-01-14T12:10:44", "from": "Майя", "text": "я ща звільнюсь і піду продавати каштани" },
    { "id": 53, "type": "message", "date": "2026-01-14T12:15:20", "from": "Макс", "text": "тримайся) ввечері принесу тобі лате і обнімашки" },
    { "id": 54, "type": "message", "date": "2026-01-14T12:16:01", "from": "Майя", "text": "лате з солоною карамеллю. і два обнімашки. це мінімальна ставка" },
    { "id": 55, "type": "message", "date": "2026-01-14T12:16:30", "from": "Макс", "text": "договір" },
    { "id": 56, "type": "message", "date": "2026-01-14T12:16:50", "from": "Майя", "text": "deal 😼" },
    { "id": 57, "type": "message", "date": "2026-02-02T20:30:00", "from": "Майя", "text": "", "media_type": "voice_message", "file": "voice/msg57.ogg" },
    { "id": 58, "type": "message", "date": "2026-02-02T20:33:10", "from": "Макс", "text": "послухав)) ну ти і вигадниця звичайно" },
    { "id": 59, "type": "message", "date": "2026-02-02T20:34:00", "from": "Майя", "text": "я серйозно! капібара кафе в києві це бізнес ідея на мільйон" },
    { "id": 60, "type": "message", "date": "2026-02-02T20:34:18", "from": "Майя", "text": "сидиш п'єш каву а поруч капібара. ВСЕ. люди платять" },
    { "id": 61, "type": "message", "date": "2026-02-02T20:35:30", "from": "Макс", "text": "а хто буде прибирати за капібарами?" },
    { "id": 62, "type": "message", "date": "2026-02-02T20:36:02", "from": "Майя", "text": "деталі. не душни 😭" },
    { "id": 63, "type": "message", "date": "2026-02-14T09:01:11", "from": "Макс", "text": "з днем валентина, мала ❤️" },
    { "id": 64, "type": "message", "date": "2026-02-14T09:05:42", "from": "Майя", "text": "ооо ти ше і романтік" },
    { "id": 65, "type": "message", "date": "2026-02-14T09:06:00", "from": "Майя", "text": "люблю тебе більше ніж лате. а це багато" },
    { "id": 66, "type": "message", "date": "2026-02-14T09:06:21", "from": "Майя", "text": "сьогодні з мене вечеря. борщ не їмо, борщ це сім'я 😼" },
    { "id": 67, "type": "message", "date": "2026-02-14T09:07:10", "from": "Макс", "text": "ахаха бідний хом'як, вічно під підозрою" },
    { "id": 68, "type": "message", "date": "2026-03-08T15:22:00", "from": "Майя", "text": "крч ми з дівчатами вирішили шо я найбільш схожа на капібару з нашої групи" },
    { "id": 69, "type": "message", "date": "2026-03-08T15:22:15", "from": "Майя", "text": "це найбільший комплімент в моєму житті" },
    { "id": 70, "type": "message", "date": "2026-03-08T15:24:30", "from": "Макс", "text": "вітаю)) а хто другий, борщ?" },
    { "id": 71, "type": "message", "date": "2026-03-08T15:25:00", "from": "Майя", "text": "борщ поза конкурсом. він легенда" },
    { "id": 72, "type": "message", "date": "2026-03-21T18:40:10", "from": "Майя", "text": "малий глянь яке небо зара" },
    { "id": 73, "type": "message", "date": "2026-03-21T18:40:20", "from": "Майя", "text": "", "media_type": "voice_message", "file": "voice/msg73.ogg" },
    { "id": 74, "type": "message", "date": "2026-03-21T18:40:55", "from": "Майя", "text": "рожеве як той зефір. вийди подивись бо пропустиш" },
    { "id": 75, "type": "message", "date": "2026-03-21T18:43:02", "from": "Макс", "text": "вийшов. реально красиво. сфоткав тобі" },
    { "id": 76, "type": "message", "date": "2026-03-21T18:43:40", "from": "Майя", "text": "оп, тепер у нас однакове небо ✨" },
    { "id": 77, "type": "message", "date": "2026-04-02T21:15:00", "from": "Макс", "text": "як пройшла презентація?" },
    { "id": 78, "type": "message", "date": "2026-04-02T21:17:23", "from": "Майя", "text": "ТИ НЕ ПОВІРИШ" },
    { "id": 79, "type": "message", "date": "2026-04-02T21:17:31", "from": "Майя", "text": "їм сподобалось. ВСЕ сподобалось" },
    { "id": 80, "type": "message", "date": "2026-04-02T21:17:40", "from": "Майя", "text": "сказали «нарешті хтось зрозумів шо ми хотіли»" },
    { "id": 81, "type": "message", "date": "2026-04-02T21:17:52", "from": "Майя", "text": "я тиждень на це вбила але воно того вартувало 😭✨" },
    { "id": 82, "type": "message", "date": "2026-04-02T21:18:30", "from": "Макс", "text": "я ні секунди не сумнівався. ти крута, мала" },
    { "id": 83, "type": "message", "date": "2026-04-02T21:19:01", "from": "Майя", "text": "дякую шо віриш в мене більше ніж я сама. серйозно" },
    { "id": 84, "type": "message", "date": "2026-04-02T21:19:15", "from": "Майя", "text": "ну все, святкуємо. з тебе піца 😼" },
    { "id": 85, "type": "message", "date": "2026-04-18T02:12:44", "from": "Майя", "text": "не спиться. знов" },
    { "id": 86, "type": "message", "date": "2026-04-18T02:13:01", "from": "Майя", "text": "думаю про всяке. про море. ми ж поїдемо влітку на море?" },
    { "id": 87, "type": "message", "date": "2026-04-18T02:15:30", "from": "Макс", "text": "поїдемо звичайно. вже навіть місце надивився" },
    { "id": 88, "type": "message", "date": "2026-04-18T02:16:11", "from": "Майя", "text": "хочу сидіти на березі вночі і шоб зорі і ти поруч" },
    { "id": 89, "type": "message", "date": "2026-04-18T02:16:30", "from": "Майя", "text": "і шоб ніяких дедлайнів. тільки ми і шум хвиль" },
    { "id": 90, "type": "message", "date": "2026-04-18T02:17:00", "from": "Макс", "text": "буде саме так. обіцяю" },
    { "id": 91, "type": "message", "date": "2026-04-18T02:17:25", "from": "Майя", "text": "ловлю на слові пельмень ✨ все, спать. добраніч" },
    { "id": 92, "type": "message", "date": "2026-05-05T14:30:10", "from": "Майя", "text": "оп я купила нам квитки на стояна на червень" },
    { "id": 93, "type": "message", "date": "2026-05-05T14:30:25", "from": "Майя", "text": "так шо 14 число не плануй нічого. ти зайнятий. мною" },
    { "id": 94, "type": "message", "date": "2026-05-05T14:32:40", "from": "Макс", "text": "ахаха ну все, записав: 14.06 — зайнятий Майєю" },
    { "id": 95, "type": "message", "date": "2026-05-05T14:33:05", "from": "Майя", "text": "найкращий запис у твоєму календарі і ти це знаєш 😼" },
    { "id": 96, "type": "message", "date": "2026-05-20T11:02:00", "from": "Макс", "text": "доброго ранку) як спалось?" },
    { "id": 97, "type": "message", "date": "2026-05-20T11:10:33", "from": "Майя", "text": "доброго) снилось шо борщ виріс до розміру капібари" },
    { "id": 98, "type": "message", "date": "2026-05-20T11:10:50", "from": "Майя", "text": "це був найкращий сон в моєму житті якшо чесно" },
    { "id": 99, "type": "message", "date": "2026-05-20T11:11:20", "from": "Макс", "text": "твоя підсвідомість це окремий вид мистецтва" },
    { "id": 100, "type": "message", "date": "2026-05-20T11:12:01", "from": "Майя", "text": "дякую я старалась 😼✨" },
    { "id": 101, "type": "message", "date": "2026-06-01T19:45:12", "from": "Майя", "text": "крч план на вечір: ти, я, серіальчик і піца з ананасами" },
    { "id": 102, "type": "message", "date": "2026-06-01T19:45:30", "from": "Майя", "text": "і не починай про ананаси. це смачно. крапка" },
    { "id": 103, "type": "message", "date": "2026-06-01T19:47:00", "from": "Макс", "text": "я мовчу як риба) о 8 буду" },
    { "id": 104, "type": "message", "date": "2026-06-01T19:47:21", "from": "Майя", "text": "чекаю малий ✨" },
    { "id": 105, "type": "message", "date": "2026-06-10T23:20:05", "from": "Майя", "text": "сьогодні бачила пару на лавці, їм років по 80" },
    { "id": 106, "type": "message", "date": "2026-06-10T23:20:22", "from": "Майя", "text": "сиділи трималися за руки і сміялись з чогось свого" },
    { "id": 107, "type": "message", "date": "2026-06-10T23:20:40", "from": "Майя", "text": "і я подумала шо хочу так само. з тобою. через 50 років сміятися з пельменів" },
    { "id": 108, "type": "message", "date": "2026-06-10T23:22:10", "from": "Макс", "text": "будемо. я навіть воду солити навчусь до того часу" },
    { "id": 109, "type": "message", "date": "2026-06-10T23:22:45", "from": "Майя", "text": "не треба. несолоні пельмені це вже наша традиція 🥲✨" },
    { "id": 110, "type": "message", "date": "2026-06-10T23:23:00", "from": "Майя", "text": "добраніч. люблю тебе" }
  ]
}
