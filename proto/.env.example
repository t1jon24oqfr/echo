# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Models (override freely; check current ids at https://openrouter.ai/models)
# Extraction needs a strong cheap model; chat needs good UA/RU style.
EXTRACT_MODEL=deepseek/deepseek-chat
CHAT_MODEL=qwen/qwen3-32b

# Any OpenAI-compatible endpoint works (e.g. self-hosted vLLM later)
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Cost guard: max LLM calls during memory extraction (each ~6k chars of chat)
MAX_MEMORY_CALLS=30
